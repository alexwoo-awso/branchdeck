PORT=8080
APP_PORT=8888
PUBLIC_BASE_URL=https://branchdeck.example.com
SESSION_SECRET=change-this-long-random-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-now

# Public access control
PUBLIC_AUTH_MODE=off
PUBLIC_AUTH_USERNAME=editor
PUBLIC_AUTH_PASSWORD=change-me

# Git checkout
GIT_REPO_URL=https://github.com/your-org/your-site.git
GIT_BRANCH=develop
GIT_CLONE_DEPTH=1
# GIT_AUTH_TOKEN=ghp_your_token
# GIT_AUTH_USERNAME=x-access-token
SYNC_INTERVAL_SECONDS=15
GIT_POLL_STRATEGY=hard-reset
REPO_SUBDIR=
INSTALL_CMD=

# Netlify Dev runtime
NETLIFY_CONTEXT=branch:develop
NETLIFY_PORT=8999
NETLIFY_SITE_ID=
NETLIFY_AUTH_TOKEN=
NETLIFY_FRAMEWORK=
NETLIFY_TARGET_PORT=
NETLIFY_FUNCTIONS=
NETLIFY_DIR=
NETLIFY_COMMAND=
NETLIFY_DEV_ARGS=
NETLIFY_OFFLINE=false

# GitHub OAuth for Decap CMS backend.base_url
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_SCOPE=repo,user

TRUST_PROXY_HEADERS=true
LOG_LEVEL=info

# Traefik labels
TRAEFIK_ENABLE=true
TRAEFIK_HOST=branchdeck.example.com
TRAEFIK_ENTRYPOINTS=websecure
TRAEFIK_TLS=true
TRAEFIK_EXTERNAL_NETWORK=true
TRAEFIK_NETWORK_NAME=traefik
